{
  "name": "musical-keyboard-exe",
  "version": "1.0.0",
  "description": "Musical Keyboard - Cross-Platform Virtual Instrument Desktop Application",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:exe": "npm run build && electron-builder",
    "build:all": "npm run build && electron-builder --win --x64 --publish=never",
    "dist": "npm run build:all",
    "start": "electron .",
    "preview": "vite preview",
    "flutter:build": "flutter build windows --release",
    "flutter:run": "flutter run -d web-server --web-port 3000"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "@tanstack/react-query": "^4.24.4",
    "lucide-react": "^0.263.1",
    "clsx": "^1.2.1",
    "tailwind-merge": "^1.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "typescript": "^4.9.3",
    "vite": "^4.1.0",
    "electron": "^22.0.0",
    "electron-builder": "^23.6.0",
    "tailwindcss": "^3.2.7",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.21"
  },
  "build": {
    "appId": "com.balasekhar.musical-keyboard",
    "productName": "Musical Keyboard",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "lib/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
