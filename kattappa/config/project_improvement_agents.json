{
  "mode": "standalone_approval_gated_improvement_agent",
  "local_registry": "docs/IMPROVEMENT_REGISTRY.md",
  "rule": "Kattappa observes only its own setup, run, test, build, UI, and workflow signals. Improvements are proposals until approved. Approved sanitized improvements stay in the local project registry unless the user explicitly asks to publish them.",
  "runtime_endpoints": {
    "registry": "GET /projects/improvement-agents",
    "observe_projects": "POST /projects/improvement-agents/observe",
    "check_local_improvements": "POST /projects/improvement-agents/check-shared",
    "approve_or_reject_proposal": "POST /improvements/{improvement_id}",
    "list_proposals": "GET /improvements"
  },
  "approval_flow": [
    "observe project signals",
    "create pending improvement proposal",
    "wait for local approval",
    "write approved sanitized proposal to docs/IMPROVEMENT_REGISTRY.md",
    "keep the proposal local unless user explicitly requests Git publication",
    "check local improvements",
    "create pending proposal only when local review finds a new item",
    "adopt only after local approval"
  ],
  "auto_apply": false,
  "publish_never_include": [
    "raw chat history",
    "private task context",
    "approval private notes",
    "credentials",
    "secrets",
    "sensitive local files",
    "raw audio",
    "private security footage",
    "medical or personal learning data"
  ],
  "projects": {
    "kattappa": {
      "name": "Kattappa AI OS Assistant",
      "agent": "backend.agents.self_improver + backend.core.self_evolution",
      "policy_doc": "kattappa/docs/self_improvement_protocol.md",
      "checks": ["setup", "run", "backend health", "frontend build", "approval queue", "local improvements"]
    }
  }
}
